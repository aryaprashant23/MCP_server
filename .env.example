GROQ_API_KEY=your_groq_api_key_here
APP_STORE_APP_ID=your_ios_app_id_here
PLAY_STORE_APP_ID=your_android_package_name_here
TARGET_EMAIL_ALIAS=your_email@example.com

# Google OAuth 2.0 (for MCP Google Workspace server)
# Create at: GCP Console > APIs & Services > Credentials > OAuth 2.0 Client ID (Desktop App)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Set to 'true' to skip MCP servers and output locally only
DRY_RUN=false
